# =============================================================================
# G-Lab Environment Variables
# Copy to .env and fill in required values
# =============================================================================

# --- Neo4j (Required for Phase 1) ---
NEO4J_URI=bolt://localhost:7687    # Neo4j Bolt protocol URI
NEO4J_USER=neo4j                   # Neo4j username
NEO4J_PASSWORD=                    # Neo4j password (required, no default)

# --- Application ---
GLAB_DATA_DIR=/data                # SQLite DB, NDJSON logs, session exports
GLAB_LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# --- Phase 2+: LLM Gateway (Copilot feature) ---
# Get your key at https://openrouter.ai — required for AI Copilot
OPENROUTER_API_KEY=                       # OpenRouter API key (leave empty to disable Copilot)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # API base URL (change only if self-hosting)

# --- Phase 3+: Vector Store (Document Library feature) ---
# ChromaDB is managed by Docker Compose — these override the defaults if needed.
CHROMA_HOST=chromadb               # ChromaDB service name (Docker) or hostname (local dev: localhost)
CHROMA_PORT=8000                   # ChromaDB internal port (mapped to host:8100 in docker-compose.yml)
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Sentence-transformers model for embedding documents and queries
